{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "script": {
            "title": "Script",
            "description": "JavaScript script to evaluate.",
            "type": "string",
            "format": "gio-code-editor",
            "gioConfig": {
                "monacoLanguage": "javascript"
            }
        },
        "readContent": {
            "title": "Read content",
            "description": "Enable to read the content of the request or response in your script.",
            "type": "boolean",
            "default": false
        }
    },
    "dependencies": {
        "readContent": {
            "oneOf": [
                {
                    "properties": {
                        "readContent": {
                            "const": true
                        },
                        "overrideContent": {
                            "title": "Override content",
                            "description": "Enable to override the content with the value returned by your script.",
                            "type": "boolean",
                            "default": false
                        }
                    }
                },
                {
                    "properties": {
                        "readContent": {
                            "const": false
                        }
                    }
                }
            ]
        }
    },
    "required": ["script"]
}
