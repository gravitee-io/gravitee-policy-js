{
    "id": "api-response-override",
    "name": "api-response-override",
    "apiVersion": "1.0",
    "definitionVersion": "4.0.0",
    "type": "proxy",
    "listeners": [
        {
            "type": "http",
            "paths": [{ "path": "/test" }],
            "entrypoints": [{ "type": "http-proxy" }]
        }
    ],
    "endpointGroups": [
        {
            "name": "default",
            "type": "http-proxy",
            "endpoints": [
                {
                    "name": "backend",
                    "type": "http-proxy",
                    "configuration": { "target": "http://localhost:8080/team" }
                }
            ]
        }
    ],
    "flows": [
        {
            "name": "flow-1",
            "enabled": true,
            "selectors": [{ "type": "http", "path": "/", "pathOperator": "STARTS_WITH" }],
            "request": [],
            "response": [
                {
                    "name": "JS",
                    "enabled": true,
                    "policy": "js",
                    "configuration": {
                        "readContent": true,
                        "overrideContent": true,
                        "script": "var body = JSON.parse(response.content());\nbody.message = 'Hello Universe!';\nresponse.headers().set('X-Phase', 'on-response');\nresponse.content(JSON.stringify(body));"
                    }
                }
            ]
        }
    ]
}
