{
    "id": "api-request-context-attrs",
    "name": "api-request-context-attrs",
    "apiVersion": "1.0",
    "definitionVersion": "4.0.0",
    "type": "proxy",
    "listeners": [
        {
            "type": "http",
            "paths": [{ "path": "/test" }],
            "entrypoints": [{ "type": "http-proxy" }]
        }
    ],
    "endpointGroups": [
        {
            "name": "default",
            "type": "http-proxy",
            "endpoints": [
                {
                    "name": "backend",
                    "type": "http-proxy",
                    "configuration": { "target": "http://localhost:8080/foobar" }
                }
            ]
        }
    ],
    "flows": [
        {
            "name": "flow-1",
            "enabled": true,
            "selectors": [{ "type": "http", "path": "/", "pathOperator": "STARTS_WITH" }],
            "request": [
                {
                    "name": "JS-set",
                    "enabled": true,
                    "policy": "js",
                    "configuration": {
                        "script": "context.set('my-key', 'my-value');\ncontext.setAttribute('other-key', 'other-value');"
                    }
                },
                {
                    "name": "JS-read-remove",
                    "enabled": true,
                    "policy": "js",
                    "configuration": {
                        "script": "request.headers().set('X-My-Key', context.get('my-key'));\nrequest.headers().set('X-Other-Key', context.getAttribute('other-key'));\ncontext.remove('other-key');\nrequest.headers().set('X-Removed', String(context.get('other-key')));"
                    }
                }
            ],
            "response": []
        }
    ]
}
